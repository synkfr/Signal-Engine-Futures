# =============================================
# SignalEngine v2 — Configuration
# =============================================

# Binance Futures API (Testnet or Mainnet)
BINANCE_API_KEY=your_api_key
BINANCE_SECRET_KEY=your_secret_key
BINANCE_TESTNET=true

# Demo Trading (places real orders on Binance Testnet with fake USDT)
ENABLE_TESTNET_ORDERS=true

# DANGER: Live Mainnet Trading (requires explicit opt-in)
# ENABLE_LIVE_ORDERS=true

# Number of top-volume symbols to monitor (default: 50)
SYMBOL_COUNT=50

# Discord Webhooks
BINANCE_SIGNALS_WEBHOOK_URL=https://discord.com/api/webhooks/your_signals_webhook
BINANCE_TRADES_WEBHOOK_URL=https://discord.com/api/webhooks/your_trades_webhook
BINANCE_RESULTS_WEBHOOK_URL=https://discord.com/api/webhooks/your_results_webhook
